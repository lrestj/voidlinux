#!/bin/bash

a="Zamknout"
b="OdhlĂˇsit"
c="Restart"
d="Vypnout"
ai="\0icon\x1fsystem-lock-screen"
bi="\0icon\x1fsystem-log-out"
ci="\0icon\x1fsystem-reboot"
di="\0icon\x1fsystem-shutdown"

selected=$(echo -e "$a$ai\n$b$bi\n$c$ci\n$d$di" | fuzzel --config ~/.config/fuzzel/power.ini -d )
case $selected in
    "$a")
        lockscreen;;
    "$b")
        sleep 1; swaymsg exit;;
    "$c")
        sleep 1; loginctl reboot;;
    "$d")
        sleep 1; loginctl poweroff;;
esac

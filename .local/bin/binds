#!/bin/bash

sdir="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"

notify-send -u critical -c max -i ~/.dotfiles/icons/help.png "Klávesové zkratky:" "$(cat $sdir/2binds.txt)" 
notify-send -u critical -c maxl -i ~/.dotfiles/icons/help.png "Klávesové zkratky:" "$(cat $sdir/1binds.txt)" 
